	"order_total": "$8281.22"
  }
]</code></pre>
	</div>
	<hr />
	<p>Generate a random JSON file of customers to download</p>
	<select class="form-select mb-3" style="max-width: 250px; display: inline; margin-right: 10px" id="download_customers_num">
	  <option value="25" selected>25 (default)</option>
	  <option value="50">50</option>
	  <option value="75">75</option>
	  <option value="100">100</option>
	  <option value="250">250</option>
	  <option value="500">500</option>
	  <option value="750">750</option>
	  <option value="1000">1000</option>
</select>
 <a href="/download?limit=25" style="text-decoration: none; color: black" download="customers" id="customers_download_btn">
